# ============================================
# CruzJS App - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
#
# Most Cloudflare resources are auto-configured by:
#   npm run deploy init
#
# This file only contains secrets and external credentials.

# ============================================
# Application
# ============================================
NODE_ENV=development
APP_URL=http://localhost:5000
APP_NAME=MyCruzApp

# ============================================
# Local Development Mode
# ============================================
# Set to 'true' to use local SQLite and filesystem instead of wrangler D1/R2
# This provides a simpler dev experience without Cloudflare tooling
#
# npm run dev      - Uses local SQLite (LOCAL_DEV=true by default)
# npm run dev:cf   - Uses wrangler for D1/R2 simulation

# LOCAL_DEV=true
# LOCAL_DB_PATH=./data/local.db
# LOCAL_STORAGE_PATH=./data/storage

# ============================================
# Security Secrets
# ============================================
# Generate each with: openssl rand -base64 32

SESSION_SECRET=generate-me
CSRF_SECRET=generate-me
JWT_SECRET=generate-me
JWT_REFRESH_SECRET=generate-me

# ============================================
# Email (MailChannels)
# ============================================
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=MyCruzApp

# Optional: DKIM for better deliverability
# DKIM_DOMAIN=yourdomain.com
# DKIM_PRIVATE_KEY=your-dkim-private-key

# ============================================
# AI (Cloudflare AI Gateway)
# ============================================
# CF account ID and gateway ID are set in wrangler.toml [vars]
# Set these as Cloudflare Pages secrets for production:
#   npx wrangler pages secret put AI_API_KEY
#   npx wrangler pages secret put CF_AIG_TOKEN
AI_API_KEY=
CF_AIG_TOKEN=

# ============================================
# OAuth (Optional)
# ============================================
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Stripe (Optional)
# ============================================
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
