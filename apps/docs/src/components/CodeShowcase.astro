---
const serverCode = `<span class="kw">export const</span> <span class="fn">tasksRouter</span> = <span class="fn">router</span>({
  <span class="prop">list</span>: <span class="fn">orgProcedure</span>
    .<span class="fn">query</span>(<span class="kw">async</span> ({ <span class="param">ctx</span> }) =&gt; {
      <span class="kw">return</span> <span class="param">ctx</span>.db
        .<span class="fn">select</span>()
        .<span class="fn">from</span>(<span class="var">tasks</span>)
        .<span class="fn">where</span>(<span class="fn">eq</span>(<span class="var">tasks</span>.orgId, <span class="param">ctx</span>.org.id));
    }),

  <span class="prop">create</span>: <span class="fn">orgProcedure</span>
    .<span class="fn">input</span>(<span class="var">z</span>.<span class="fn">object</span>({ <span class="prop">title</span>: <span class="var">z</span>.<span class="fn">string</span>() }))
    .<span class="fn">mutation</span>(<span class="kw">async</span> ({ <span class="param">ctx</span>, <span class="param">input</span> }) =&gt; {
      <span class="kw">return</span> <span class="param">ctx</span>.db.<span class="fn">insert</span>(<span class="var">tasks</span>)
        .<span class="fn">values</span>({ ...<span class="param">input</span>, <span class="prop">orgId</span>: <span class="param">ctx</span>.org.id });
    }),
});`;

const clientCode = `<span class="kw">export default function</span> <span class="fn">Tasks</span>() {
  <span class="kw">const</span> { <span class="var">data</span>: <span class="var">tasks</span> } = <span class="var">trpc</span>.tasks.list.<span class="fn">useQuery</span>();

  <span class="kw">return</span> (
    &lt;<span class="comp">Page</span> <span class="prop">title</span>=<span class="str">"Tasks"</span>&gt;
      &lt;<span class="comp">DataTable</span>
        <span class="prop">data</span>={<span class="var">tasks</span>}
        <span class="prop">columns</span>={[
          { <span class="prop">header</span>: <span class="str">"Title"</span>, <span class="prop">accessorKey</span>: <span class="str">"title"</span> },
          { <span class="prop">header</span>: <span class="str">"Status"</span>, <span class="prop">accessorKey</span>: <span class="str">"status"</span> },
          { <span class="prop">header</span>: <span class="str">"Assigned"</span>, <span class="prop">accessorKey</span>: <span class="str">"assignee"</span> },
        ]}
      /&gt;
    &lt;/<span class="comp">Page</span>&gt;
  );
}`;
---

<section class="cruz-code-showcase">
  <div class="showcase-inner">
    <div class="section-header">
      <span class="section-label">See it in action</span>
      <h2 class="section-title">End-to-End Type Safety</h2>
      <p class="section-description">
        Define a tRPC procedure on the server, call it from the client.
        Full TypeScript inference — no codegen step, no runtime surprises.
      </p>
    </div>
    <div class="code-panels">
      <div class="code-panel">
        <div class="panel-header">
          <div class="panel-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="panel-label">server/routers/tasks.ts</span>
          <span class="panel-badge server-badge">Server</span>
        </div>
        <pre class="panel-code"><code set:html={serverCode} /></pre>
      </div>
      <div class="code-panel">
        <div class="panel-header">
          <div class="panel-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="panel-label">routes/tasks.tsx</span>
          <span class="panel-badge client-badge">Client</span>
        </div>
        <pre class="panel-code"><code set:html={clientCode} /></pre>
      </div>
    </div>
    <p class="code-note">
      Change the server schema — the client breaks at compile time, not in production.
    </p>
  </div>
</section>

