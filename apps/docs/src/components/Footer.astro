---
import type { Props } from '@astrojs/starlight/props';
---

<footer class="cruz-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="footer-logo">CruzJS</span>
        <p class="footer-tagline">
          The full-stack TypeScript framework for production apps.
          From database to UI — one language, one framework, on Cloudflare's edge.
        </p>
      </div>

      <div class="footer-links">
        <h4>Getting Started</h4>
        <a href="/prologue/quick-start/">Quick Start</a>
        <a href="/getting-started/installation/">Installation</a>
        <a href="/tutorial/00-introduction/">Tutorial</a>
        <a href="/getting-started/directory-structure/">Directory Structure</a>
      </div>

      <div class="footer-links">
        <h4>Features</h4>
        <a href="/frontend/components/">UI Components</a>
        <a href="/basics/trpc-routers/">tRPC Routers</a>
        <a href="/security/authentication/">Authentication</a>
        <a href="/adapters/cloudflare/">Deployment</a>
      </div>

      <div class="footer-links">
        <h4>Resources</h4>
        <a href="https://github.com/cruzjs/cruzjs">GitHub</a>
        <a href="/architecture/request-lifecycle/">Architecture</a>
        <a href="/cli/overview/">CLI Reference</a>
        <a href="/testing/getting-started/">Testing</a>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-about">
        Built by <a href="https://linkedin.com/in/kerryritter" target="_blank" rel="noopener">Kerry Ritter</a>
        at <a href="https://joinzipper.com" target="_blank" rel="noopener">Zipper</a>.
        Questions? <a href="mailto:ritter@kerryritter.com">ritter@kerryritter.com</a>
      </div>
      <div class="footer-copy">
        &copy; {new Date().getFullYear()} CruzJS. Open source under MIT.
      </div>
    </div>
  </div>
</footer>

<style>
  .cruz-footer {
    border-top: 1px solid #e5e7eb;
    background: #f9fafb;
    padding: 3.5rem 2rem 2rem;
    font-family: var(--sl-font-system);
  }

  .footer-inner {
    max-width: 68rem;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .footer-logo {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #111827;
  }

  .footer-tagline {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #6b7280;
    margin-top: 0.75rem;
    max-width: 20rem;
  }

  .footer-links h4 {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #374151;
    margin-bottom: 0.75rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: #7c3aed;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-about {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .footer-about a {
    color: #7c3aed;
    text-decoration: none;
    font-weight: 500;
  }

  .footer-about a:hover {
    text-decoration: underline;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  /* Homepage dark footer */
  :global(body:has(.cruz-hero)) .cruz-footer {
    background: #0a0714;
    border-top-color: rgba(124, 58, 237, 0.15);
  }

  :global(body:has(.cruz-hero)) .footer-logo {
    color: #e8e0f0;
  }

  :global(body:has(.cruz-hero)) .footer-tagline {
    color: #706a7a;
  }

  :global(body:has(.cruz-hero)) .footer-links h4 {
    color: #a0919f;
  }

  :global(body:has(.cruz-hero)) .footer-links a {
    color: #706a7a;
  }

  :global(body:has(.cruz-hero)) .footer-links a:hover {
    color: #c4b5fd;
  }

  :global(body:has(.cruz-hero)) .footer-bottom {
    border-top-color: rgba(255, 255, 255, 0.06);
  }

  :global(body:has(.cruz-hero)) .footer-about {
    color: #706a7a;
  }

  :global(body:has(.cruz-hero)) .footer-about a {
    color: #c4b5fd;
  }

  :global(body:has(.cruz-hero)) .footer-copy {
    color: #4a4454;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: span 2;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: span 1;
    }
  }
</style>
