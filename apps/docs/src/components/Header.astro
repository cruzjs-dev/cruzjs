---
import type { Props } from '@astrojs/starlight/props';
import Search from '@astrojs/starlight/components/Search.astro';
---

<div class="header sl-flex">
  <div class="sl-flex cruz-header-left">
    <a href="/" class="cruz-site-title">CruzJS</a>
    <nav class="cruz-nav">
      <a href="/prologue/quick-start/">Docs</a>
      <a href="/tutorial/00-introduction/">Tutorial</a>
      <a href="/cli/overview/">CLI</a>
      <a href="/getting-started/skills/">AI</a>
      <a href="/storybook/" target="_blank">CruzUI Components</a>
      <a href="/about/about/">About</a>
    </nav>
  </div>
  <div class="sl-flex cruz-header-right">
    <Search {...Astro.props} />
    <a href="https://github.com/cruzjs/cruzjs" class="cruz-github-link" aria-label="GitHub">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    </a>
  </div>
</div>

<style>
  /* Layout only — header bg/border styled globally in custom.css (always dark). */
  .header {
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .cruz-header-left {
    align-items: center;
    gap: 2rem;
    min-width: 0;
  }

  .cruz-site-title {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #f3effa;
    text-decoration: none;
  }

  .cruz-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .cruz-nav a {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(232, 224, 240, 0.65);
    text-decoration: none;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .cruz-nav a:hover {
    color: #c4b5fd;
  }

  .cruz-header-right {
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .cruz-github-link {
    display: flex;
    align-items: center;
    color: rgba(232, 224, 240, 0.65);
    transition: color 0.15s ease;
  }

  .cruz-github-link:hover {
    color: #c4b5fd;
  }

  @media (max-width: 600px) {
    .cruz-nav {
      display: none;
    }
  }
</style>
