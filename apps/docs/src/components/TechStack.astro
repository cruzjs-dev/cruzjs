---

<section class="cruz-stack">
  <div class="stack-inner">
    <div class="section-header">
      <span class="section-label">Powered by the best</span>
      <h2 class="section-title">The Stack</h2>
    </div>
    <div class="stack-grid">
      {techs.map((tech) => (
        <div class="stack-card" style={`--tech-color: ${tech.color}`}>
          <div class="stack-icon" set:html={tech.icon} />
          <h3 class="stack-name">{tech.name}</h3>
          <p class="stack-description">{tech.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cruz-stack {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .stack-inner {
    max-width: 68rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7c3aed;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 2.5rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: #111827 !important;
    border: none !important;
    padding: 0 !important;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .stack-card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    transition: all 0.3s ease;
    position: relative;
  }

  .stack-card:hover {
    transform: translateY(-4px);
    border-color: var(--tech-color);
    box-shadow: 0 20px 40px -12px color-mix(in srgb, var(--tech-color) 15%, transparent);
  }

  .stack-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin: 0 auto 1.25rem;
    border-radius: 14px;
    background: color-mix(in srgb, var(--tech-color) 10%, transparent);
    color: var(--tech-color);
  }

  .stack-name {
    font-size: 1.1rem !important;
    font-weight: 700 !important;
    color: #111827 !important;
    margin-bottom: 0.5rem !important;
    margin-top: 0 !important;
  }

  .stack-description {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #6b7280 !important;
    margin: 0 !important;
  }

  @media (max-width: 900px) {
    .stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .stack-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
