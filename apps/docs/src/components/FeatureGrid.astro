---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Type-Safe APIs",
    description: "End-to-end type safety with tRPC. Define procedures on the server, call from the client — your IDE autocompletes everything. No codegen, no REST boilerplate.",
    accent: "#7c3aed",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
    title: "124+ UI Components",
    description: "Production-grade React library — primitives, forms, data tables, layouts, marketing blocks. Themed with CSS variables, accessible, mobile-responsive.",
    accent: "#2563eb",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: "Multi-Tenant Auth",
    description: "Sessions, organizations, RBAC (Owner, Admin, Member, Viewer), invitation flows, and audit logging. Every endpoint scoped to the current org.",
    accent: "#059669",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>`,
    title: "Ships on Cloudflare",
    description: "Native D1, KV, R2, Queues, and Workers AI on Cloudflare Workers/Pages. A runtime-adapter layer underpins the multi-cloud roadmap.",
    accent: "#d97706",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
    title: "DI Container",
    description: "Inversify-powered dependency injection. @Injectable() classes, @Module() composition, constructor injection. Swap implementations without changing a line.",
    accent: "#dc2626",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
    title: "One CLI",
    description: "cruz dev starts your server. cruz db generate creates migrations. cruz deploy production ships your app. Scaffold Workers, Workflows, and Queues with cruz new.",
    accent: "#7c3aed",
  },
];
---

<section class="cruz-features">
  <div class="features-inner">
    <div class="section-header">
      <span class="section-label">Everything you need</span>
      <h2 class="section-title">Why CruzJS?</h2>
      <p class="section-description">
        Stop wiring together a dozen libraries. Get a single coherent stack where
        every layer — database to UI — is designed to work together.
      </p>
    </div>
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card" style={`--card-accent: ${feature.accent}`}>
          <div class="feature-icon" set:html={feature.icon} />
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cruz-features {
    padding: 5rem 2rem;
    background: #ffffff;
  }

  .features-inner {
    max-width: 68rem;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7c3aed;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 2.5rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: #111827 !important;
    margin-bottom: 1rem !important;
    border: none !important;
    padding: 0 !important;
  }

  .section-description {
    font-size: 1.15rem;
    color: #6b7280 !important;
    max-width: 36rem;
    margin: 0 auto !important;
    line-height: 1.7;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    position: relative;
    padding: 2rem;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-accent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.08);
    border-color: transparent;
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-accent) 10%, transparent);
    color: var(--card-accent);
    margin-bottom: 1.25rem;
  }

  .feature-title {
    font-size: 1.125rem !important;
    font-weight: 700 !important;
    color: #111827 !important;
    margin-bottom: 0.5rem !important;
    margin-top: 0 !important;
  }

  .feature-description {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #6b7280 !important;
    margin: 0 !important;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 2rem !important;
    }
  }
</style>
