{
  "name": "@cruzjs/docs",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run build:storybook && astro build",
    "build:storybook": "cd ../../packages/ui && npm run storybook:build && rm -rf ../../apps/docs/public/storybook && cp -r storybook-static ../../apps/docs/public/storybook",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "astro": "astro",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.0"
  }
}
