{
  "name": "cruzjs",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "setup": "npx tsx packages/cli/src/index.tsx setup",
    "init": "npx tsx packages/cli/src/index.tsx init",
    "build": "npx tsx packages/cli/src/index.tsx build",
    "dev": "LOCAL_DEV=true npx tsx packages/cli/src/index.tsx dev",
    "dev:stop": "npx tsx packages/cli/src/index.tsx dev stop",
    "dev:restart": "LOCAL_DEV=true npx tsx packages/cli/src/index.tsx dev restart",
    "dev:status": "npx tsx packages/cli/src/index.tsx dev status",
    "migrate": "npx tsx packages/cli/src/index.tsx db migrate",
    "deploy": "npx tsx packages/cli/src/index.tsx deploy",
    "cruz": "npx tsx packages/cli/src/index.tsx",
    "start": "npx react-router-serve ./dist/server/index.js",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "build:all": "npm run build --workspace=packages/core && npm run build --workspace=packages/saas && npm run build --workspace=packages/start && npm run build --workspace=packages/ui && npm run build --workspace=packages/cli",
    "typecheck": "tsc --noEmit"
  },
